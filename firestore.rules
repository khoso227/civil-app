rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'status', 'ownerId'])
        && data.keys().size() >= 3
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.status in ["Planning", "In Progress", "Completed", "On Hold"]
        && data.ownerId == request.auth.uid
        && (data.budget == null || data.budget is number)
        && (data.location == null || data.location is string);
    }

    function isValidTask(data) {
      return data.keys().hasAll(['projectId', 'title', 'status'])
        && data.projectId is string && isValidId(data.projectId)
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.status in ["Todo", "In Progress", "Done"]
        && (data.priority == null || data.priority in ["Low", "Medium", "High"])
        && (data.assigneeName == null || data.assigneeName is string);
    }

    function isValidInventory(data) {
      return data.keys().hasAll(['projectId', 'name', 'quantity', 'unit'])
        && data.projectId is string && isValidId(data.projectId)
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.quantity is number
        && data.unit is string;
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['projectId', 'url', 'userId'])
        && data.url is string && data.url.size() < 2000
        && data.userId == request.auth.uid
        && data.projectId is string && isValidId(data.projectId)
        && (data.analysis == null || data.analysis is string);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'userId', 'userName'])
        && data.text is string && data.text.size() > 0 && data.text.size() <= 2000
        && data.userId == request.auth.uid
        && data.userName is string
        && (data.createdAt == null || data.createdAt == request.time);
    }

    function isValidEquipment(data) {
      return data.keys().hasAll(['name', 'type', 'status'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.type is string
        && data.status in ["Active", "Maintenance", "Idle", "Offline"]
        && (data.operator == null || data.operator is string);
    }

    function isValidProfile(data) {
      return (data.roles == null || data.roles is list)
        && (data.language == null || data.language in ["en", "ur", "sd"])
        && (data.email == null || data.email is string)
        && (data.displayName == null || data.displayName is string)
        && (data.updatedAt == null || data.updatedAt == request.time);
    }

    // --- Collection Matches ---

    // 1. Users - Strictly Isolated PII
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidProfile(incoming());
      allow update: if isOwner(userId) && isValidProfile(incoming())
        // Prevent self-assignment of roles unless they were already there (immutable check)
        && (incoming().roles == existing().roles || incoming().roles == null);
    }

    // 2. Projects - Owner Managed
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidProject(incoming());
      allow update: if isOwner(existing().ownerId) && isValidProject(incoming());
      allow delete: if isOwner(existing().ownerId);
    }

    // 3. Project Resources - CollectionGroup support
    match /{path=**}/tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTask(incoming());
      allow update: if isSignedIn() && isValidTask(incoming());
      allow delete: if isSignedIn();
    }

    match /{path=**}/inventory/{itemId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidInventory(incoming());
      allow delete: if isSignedIn();
    }

    match /{path=**}/photos/{photoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPhoto(incoming());
      allow update: if isSignedIn() && isValidPhoto(incoming());
      allow delete: if isOwner(existing().userId);
    }

    // 4. Global Top-level Collections
    match /team_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(incoming());
      allow update, delete: if false;
    }

    match /equipment/{equipmentId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidEquipment(incoming());
      allow delete: if isSignedIn();
    }

    match /sitePhotos/{photoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPhoto(incoming());
      allow update: if isSignedIn() && isValidPhoto(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }
  }
}

